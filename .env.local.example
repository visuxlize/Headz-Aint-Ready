# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (e.g. Supabase Postgres)
DATABASE_URL=
# Optional: Supabase Connect → Direct (non-pooler). Improves automatic DDL for Tickets (`barber_profile_id`).
# DATABASE_URL_NON_POOLING=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — same value as in Vercel env; secures GET /api/cron/no-show-checker (generate: openssl rand -hex 32)
# CRON_SECRET=

# Email (optional)
RESEND_API_KEY=
RESEND_FROM=

# Squire (POS / booking Partner API — https://www.getsquire.com)
SQUIRE_API_KEY=           # From Squire Partner Portal
SQUIRE_WEBHOOK_SECRET=    # Set in Squire webhook settings (HMAC for /api/squire/webhook)
SQUIRE_LOCATION_ID=       # Your shop's Squire location ID

# Legacy (remove after Squire is fully live)
# SQUARE_ACCESS_TOKEN=
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# SQUARE_LOCATION_ID=
# SQUARE_TERMINAL_DEVICE_ID=
