# Copy to .env.local and fill in values (never commit .env.local)

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database — Project Settings → Database → Connection string (Transaction pooler :6543 recommended)
DATABASE_URL=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Square — developer.squareup.com → Applications → your app
# OAuth / Credentials: create a Sandbox (or Production) access token with payments + devices
SQUARE_ACCESS_TOKEN=
# Locations API or Dashboard → Locations → copy Location ID (looks like L...)
SQUARE_LOCATION_ID=
# Optional: "production" for live, otherwise Sandbox is used
# SQUARE_ENVIRONMENT=sandbox

# Webhooks (production): URL must match Square app webhook URL exactly
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.com/api/square/webhook

# Email receipts (optional)
# RESEND_API_KEY=
# RESEND_FROM="Headz <receipts@yourdomain.com>"
